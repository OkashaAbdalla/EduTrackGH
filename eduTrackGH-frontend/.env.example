# Production builds: required. Full API URL including /api (e.g. https://your-api.onrender.com/api).
VITE_API_URL=http://localhost:5000/api

# Development: default uses same-origin /api + Vite proxy (fixes Brave/Firefox cross-origin issues). Set to 0 to call VITE_API_URL directly instead.
# VITE_DEV_PROXY=0

# Optional: proxy target if the API is not on localhost:5000 (used only by Vite dev server).
# VITE_PROXY_TARGET=http://127.0.0.1:5000

# Must match backend ADMIN_LOGIN_PATH (admin page: /{this value})
VITE_ADMIN_LOGIN_PATH=secure-admin-CHANGE_ME

# Google OAuth — Web client ID (same value as backend GOOGLE_CLIENT_ID)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173, your production frontend URL
VITE_GOOGLE_CLIENT_ID=
