# Backend API base URL (must include /api). Set in Vercel to your Render URL, e.g. https://your-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Must match backend ADMIN_LOGIN_PATH (admin page: /{this value})
VITE_ADMIN_LOGIN_PATH=secure-admin-CHANGE_ME

# Optional (Google OAuth if used)
# VITE_GOOGLE_CLIENT_ID=
