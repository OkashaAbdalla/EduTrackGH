# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/edutrack

# JWT Configuration (must match generateToken.js)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (Brevo SMTP)
BREVO_SMTP_USER=your_smtp_login@example.com
BREVO_SMTP_PASS=your_smtp_key
BREVO_FROM_EMAIL=your_verified_sender@example.com
# Optional overrides (defaults shown)
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587

# Frontend Origin(s) for CORS + Socket.IO — must match the browser address exactly (scheme + host + port, no trailing slash).
# Use commas for multiple values (prod + preview, www + apex). Include http://127.0.0.1:5173 if teachers open that URL.
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Must match frontend VITE_ADMIN_LOGIN_PATH (admin login API: POST /api/auth/:ADMIN_LOGIN_PATH)
ADMIN_LOGIN_PATH=secure-admin-CHANGE_ME

# Optional: Other configurations
ADMIN_EMAIL=admin@example.com
LOG_LEVEL=debug
